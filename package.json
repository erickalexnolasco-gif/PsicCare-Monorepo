{
  "name": "psicare",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:app": "yarn workspace @psicare/app dev",
    "dev:marketing": "yarn workspace @psicare/marketing dev",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "db:types": "supabase gen types typescript --project-id $SUPABASE_PROJECT_REF > packages/db/src/database.types.ts"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.6.3",
    "prettier": "^3.4.2"
  },
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": ">=18.17"
  }
}
